{
  "compilerOptions": {
    "target": "ES2022", // Mengganti ES5 yang sudah usang
    "lib": ["ESNext", "DOM"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext", // Mengganti commonjs agar lebih modern
    "moduleResolution": "bundler", // Mengganti node/node10 yang sudah usang untuk Next.js
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": ["node_modules"]
}